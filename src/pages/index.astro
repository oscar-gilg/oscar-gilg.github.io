---
import { Image } from "astro:assets";
import PageLayout from "@/layouts/Base.astro";
import profile from "@/assets/profile.jpg";
---

<PageLayout meta={{ title: "Oscar Gilg" }}>
	<section class="flex flex-col-reverse items-start gap-6 sm:flex-row sm:gap-8">
		<div class="flex-1 space-y-4">
			<h1 class="title">Oscar Gilg</h1>
			<p class="leading-relaxed">
				I work on empirical AI welfare research at MATS 9.0, mentored by
				<a class="cactus-link" href="https://patrickbutlin.com/" rel="noreferrer" target="_blank"
					>Patrick Butlin</a
				>.
			</p>
		</div>
		<Image
			alt="Oscar Gilg"
			class="border-accent/30 aspect-square w-32 shrink-0 rounded-full border-2 object-cover shadow-sm sm:w-40"
			loading="eager"
			src={profile}
			width={400}
			widths={[160, 240, 320, 480]}
		/>
	</section>

	<section class="mt-12">
		<h2 class="title text-accent mb-4 text-xl">Projects</h2>
		<ul class="space-y-4" role="list">
			<li>
				<div class="flex items-baseline justify-between gap-4">
					<a
						class="cactus-link font-semibold"
						href="https://github.com/oscar-gilg/zombuul"
						rel="noreferrer"
						target="_blank">Zombuul</a
					>
					<span class="text-muted shrink-0 text-xs">2026</span>
				</div>
				<p class="text-muted mt-1">
					I built a Claude Code plugin for launching autonomous research agents with access to
					GPUs.
				</p>
			</li>
			<li>
				<div class="flex items-baseline justify-between gap-4">
					<span class="font-semibold">Personas use a shared preference vector</span>
					<span class="text-muted shrink-0 text-xs">MATS 9.0, 2026</span>
				</div>
				<p class="text-muted mt-1">
					With Patrick Butlin (
					<a
						class="cactus-link"
						href="https://www.lesswrong.com/posts/pxC2RAeoBrvK8ivMf/models-have-linear-representations-of-what-tasks-they-like-1"
						rel="noreferrer"
						target="_blank">post</a
					>,
					<a
						class="cactus-link"
						href="https://github.com/oscar-gilg/Preferences"
						rel="noreferrer"
						target="_blank">code</a
					>; preprint forthcoming).
				</p>
			</li>
			<li>
				<div class="flex items-baseline justify-between gap-4">
					<a
						class="cactus-link font-semibold"
						href="https://arxiv.org/abs/2602.05532"
						rel="noreferrer"
						target="_blank">Split Personality Training</a
					>
					<span class="text-muted shrink-0 text-xs">SPAR 2025</span>
				</div>
				<p class="text-muted mt-1">
					Trigger-conditioned persona fine-tuning. Accepted at ICML 2026.
				</p>
			</li>
		</ul>
	</section>

	<section class="mt-12 space-y-4">
		<h2 class="title text-accent mb-4 text-xl">Bio</h2>
		<p class="leading-relaxed">
			I studied Mathematics and Computer Science at Oxford, graduating in 2023 with a First-Class
			degree and Master's Distinction. Reading Dennett's <em>Consciousness Explained</em> and
			<em>From Bacteria to Bach and Back</em> got me interested in philosophy of mind, and in my
			final-year dissertation I tried to operationalise properties of consciousness and described
			how they could arise in a hierarchical generative model.
		</p>
		<p class="leading-relaxed">
			After Oxford I spent two months in Bochum working with
			<a
				class="cactus-link"
				href="https://www.francoiskammerer.com/"
				rel="noreferrer"
				target="_blank">François Kammerer</a
			> on formalising illusionist theories of consciousness, then joined Optiver in Amsterdam as
			a quantitative trader. I spent over a year on a 6-trader equities desk; trading taught me
			to test hypotheses fast and make decisions under uncertainty.
		</p>
		<p class="leading-relaxed">
			I had first read Bostrom's <em>Superintelligence</em> as a teenager and dismissed the
			timelines as too aggressive. When o3 was released that intuition flipped: I left Optiver
			and applied to MATS, where I now do empirical AI welfare research with six-month extension
			funding.
		</p>
	</section>

	<section class="mt-12">
		<h2 class="title text-accent mb-4 text-xl">CV</h2>
		<p>
			<a class="cactus-link" href="/cv.pdf" rel="noreferrer" target="_blank">View CV (PDF)</a>
		</p>
	</section>

	<section class="mt-12">
		<h2 class="title text-accent mb-4 text-xl">Contact</h2>
		<ul class="list-disc space-y-1 ps-5" role="list">
			<li>
				Email:
				<span
					class="cactus-link cursor-pointer"
					data-eu="oscar.gilg18"
					data-ed="gmail.com"
					role="button"
					tabindex="0">oscar.gilg18 [at] gmail [dot] com</span
				>
			</li>
			<li>
				<a
					class="cactus-link"
					href="https://github.com/oscar-gilg"
					rel="noreferrer"
					target="_blank">github.com/oscar-gilg</a
				>
			</li>
			<li>
				<a
					class="cactus-link"
					href="https://www.linkedin.com/in/oscar-gilg"
					rel="noreferrer"
					target="_blank">linkedin.com/in/oscar-gilg</a
				>
			</li>
		</ul>
	</section>

	<script is:inline>
		document.querySelectorAll("[data-eu]").forEach(function (el) {
			function open() {
				var u = el.getAttribute("data-eu");
				var d = el.getAttribute("data-ed");
				window.location.href = "mai" + "lto:" + u + "@" + d;
			}
			el.addEventListener("click", open);
			el.addEventListener("keydown", function (e) {
				if (e.key === "Enter" || e.key === " ") {
					e.preventDefault();
					open();
				}
			});
		});
	</script>
</PageLayout>
